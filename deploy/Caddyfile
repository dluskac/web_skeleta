# ── SKELETA — statický web (skeleta.cz) ──────────────────────────────
# Umístění na serveru: /etc/caddy/Caddyfile (v kontejneru pro skeleta web)
# Po změně: caddy validate --config /etc/caddy/Caddyfile && systemctl reload caddy
# Certifikáty (Let's Encrypt) vystaví Caddy automaticky — vyžaduje, aby DNS
# skeleta.cz + www.skeleta.cz mířilo na tento server a porty 80+443 byly otevřené.

skeleta.cz, www.skeleta.cz {
	# www → apex
	@www host www.skeleta.cz
	redir @www https://skeleta.cz{uri} permanent

	root * /srv/skeleta-web
	file_server
	encode gzip zstd

	# Staré adresy z dob Webnode webu, na které vedou odkazy z internetu
	redir /kontakt / permanent
	redir /kontakt/ / permanent

	# Poptávkový formulář → vlastní backend (deploy/poptavka.py, systemd
	# služba "poptavka"); doručuje přímo na MX, žádná třetí strana
	reverse_proxy /api/poptavka localhost:8090

	header {
		# HSTS zprvu jen 1 den; po ~2 týdnech stabilního provozu zvednout na 31536000
		Strict-Transport-Security "max-age=86400"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "strict-origin-when-cross-origin"
		# Formulář jde na vlastní /api/poptavka → stačí connect-src 'self'
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self'; frame-src https://www.openstreetmap.org; frame-ancestors 'self'; base-uri 'self'; object-src 'none'"
		-Server
	}

	log {
		output file /var/log/caddy/skeleta-access.log
		format json
	}
}

# ── LAN náhled (jen z domácí sítě, port 8080, bez HTTPS redirectu) ──
# Ve firewallu kontejneru je 8080 povolen pouze pro 192.168.1.0/24;
# router ho z internetu nepřesměrovává. Adresa: http://192.168.1.90:8080
http://:8080 {
	root * /srv/skeleta-web
	file_server
	encode gzip zstd
}
